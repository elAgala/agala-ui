{
  "name": "@el-agala/ui",
  "version": "0.1.7",
  "description": "Agala UI — A zero-dependency Vue 3 component library with atomic design tokens, theming, and accessibility.",
  "type": "module",
  "module": "./dist/agala-ui.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/agala-ui.es.js"
      }
    }
  },
  "files": [
    "dist",
    "AI_CONTEXT.md",
    "skills"
  ],
  "scripts": {
    "dev": "vite",
    "build:lib": "vue-tsc --noEmit && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepublishOnly": "npm run build:lib"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "typescript": "~5.6.0",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.3",
    "vite-plugin-lib-inject-css": "^2.2.1",
    "vue-tsc": "^3.2.8"
  },
  "dependencies": {
    "vue": "^3.5.33"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/el-agala/ui.git"
  },
  "author": "Agala",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "vue",
    "vue3",
    "ui",
    "components",
    "design-system",
    "agala",
    "zero-dependency",
    "theming",
    "accessibility"
  ]
}
