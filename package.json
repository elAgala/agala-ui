{
  "name": "@agala/ui",
  "version": "0.1.0",
  "description": "Agala UI — A clean, versatile Vue 3 component library with atomic design tokens.",
  "type": "module",
  "module": "./dist/agala-ui.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/agala-ui.es.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build:lib": "vue-tsc --noEmit && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "typescript": "~5.6.0",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.3",
    "vite-plugin-lib-inject-css": "^2.2.1",
    "vue-tsc": "^3.2.8"
  },
  "dependencies": {
    "vue": "^3.5.33"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/agala/ui.git"
  },
  "author": "Agala",
